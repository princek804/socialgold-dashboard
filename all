<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Social Gold — Pinterest Team Dashboard</title>
<style>
/* ===== RESET & BASE ===== */
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Segoe UI',system-ui,sans-serif;font-size:14px}
body{background:#0F0D0A;color:#F0E8D8;overflow:hidden}

/* ===== CSS VARIABLES ===== */
:root{
  --gold:#E8A020;--gold-l:#FAC75A;--gold-d:#A06810;
  --dark:#0F0D0A;--surface:#1A1510;--card:#231E16;--card2:#2A2218;
  --border:rgba(232,160,32,0.16);--border2:rgba(232,160,32,0.28);
  --text:#F0E8D8;--muted:#9A8468;--muted2:#C4A878;
  --pin:#E60023;--green:#22C55E;--blue:#3B8BF0;--red:#E05050;
  --success-bg:rgba(34,197,94,0.12);--success-border:rgba(34,197,94,0.3);
  --danger-bg:rgba(230,0,35,0.12);--danger-border:rgba(230,0,35,0.3);
}

/* ===== LAYOUT ===== */
#app{display:flex;height:100vh}
#sidebar{width:230px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;z-index:10}
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* ===== SIDEBAR ===== */
.logo-area{padding:18px 16px 14px;border-bottom:1px solid var(--border)}
.pin-badge{display:inline-block;background:var(--pin);color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;letter-spacing:.08em;margin-bottom:5px}
.logo-name{font-size:16px;font-weight:700;color:var(--gold);letter-spacing:.02em}
.logo-domain{font-size:10px;color:var(--muted);margin-top:2px;letter-spacing:.06em}

.nav{flex:1;padding:10px 0;overflow-y:auto}
.nav::-webkit-scrollbar{width:3px}
.nav::-webkit-scrollbar-thumb{background:var(--border)}
.nav-section{padding:10px 16px 4px;font-size:9px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 16px;font-size:12px;color:var(--muted);cursor:pointer;border-left:2px solid transparent;transition:all .15s;user-select:none}
.nav-item:hover{color:var(--gold-l);background:rgba(232,160,32,.05)}
.nav-item.active{color:var(--gold);border-left-color:var(--gold);background:rgba(232,160,32,.08)}
.nav-icon{width:16px;text-align:center;flex-shrink:0;font-size:13px}
.nav-count{margin-left:auto;background:var(--gold);color:var(--dark);font-size:9px;font-weight:700;padding:1px 5px;border-radius:8px}

.sidebar-bottom{padding:12px 16px;border-top:1px solid var(--border)}
.user-info{display:flex;align-items:center;gap:10px}
.user-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--pin));display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.user-name{font-size:12px;color:var(--text);font-weight:500}
.user-role{font-size:9px;color:var(--gold);background:rgba(232,160,32,.12);border:1px solid var(--border);padding:1px 6px;border-radius:8px;margin-top:2px;display:inline-block;letter-spacing:.06em}

/* ===== TOPBAR ===== */
#topbar{display:flex;align-items:center;justify-content:space-between;padding:13px 20px;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0}
.topbar-left{display:flex;align-items:center;gap:12px}
.page-title{font-size:15px;font-weight:600;color:var(--text)}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
.sync-label{font-size:10px;color:var(--green)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.topbar-right{display:flex;align-items:center;gap:10px}
.domain-chip{background:rgba(232,160,32,.1);border:1px solid var(--border);color:var(--gold);font-size:10px;padding:4px 11px;border-radius:20px}
.notif-bell{cursor:pointer;color:var(--muted);font-size:16px;position:relative}
.notif-count{position:absolute;top:-4px;right:-4px;background:var(--pin);color:#fff;font-size:8px;font-weight:700;width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center}

/* ===== CONTENT AREA ===== */
#content-area{flex:1;overflow-y:auto;padding:20px;background:var(--dark)}
#content-area::-webkit-scrollbar{width:4px}
#content-area::-webkit-scrollbar-thumb{background:var(--border)}

/* ===== PANELS ===== */
.panel{display:none}
.panel.active{display:block}

/* ===== TOAST ===== */
#toast{position:fixed;top:18px;right:20px;background:var(--card2);border:1px solid var(--success-border);color:var(--green);font-size:12px;padding:10px 16px;border-radius:8px;z-index:9999;opacity:0;pointer-events:none;transition:opacity .25s;max-width:260px}
#toast.show{opacity:1}

/* ===== STAT CARDS ===== */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px}
.stat-grid-3{grid-template-columns:repeat(3,1fr)}
.stat-grid-2{grid-template-columns:repeat(2,1fr)}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px 16px}
.stat-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;margin-bottom:6px}
.stat-val{font-size:21px;font-weight:700;line-height:1.1}
.sv-gold{color:var(--gold)}
.sv-green{color:var(--green)}
.sv-red{color:var(--red)}
.sv-blue{color:var(--blue)}
.stat-sub{font-size:10px;color:var(--muted);margin-top:4px}
.stat-trend-up{color:var(--green)}
.stat-trend-down{color:var(--red)}

/* ===== SECTION TITLES ===== */
.sec-title{font-size:10px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.14em;margin-bottom:12px}

/* ===== CARDS ===== */
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:16px}
.card-sm{padding:12px}

/* ===== GRID LAYOUTS ===== */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px}
.grid-7030{display:grid;grid-template-columns:70fr 30fr;gap:14px;margin-bottom:16px}

/* ===== CHARTS ===== */
.mini-chart{display:flex;align-items:flex-end;gap:4px;height:56px;margin:8px 0 4px}
.bar{flex:1;border-radius:3px 3px 0 0;cursor:pointer;transition:opacity .15s}
.bar:hover{opacity:.75}
.bar-gold{background:rgba(232,160,32,.35)}
.bar-gold:hover{background:var(--gold)}
.bar-pin{background:rgba(230,0,35,.35)}
.bar-pin:hover{background:var(--pin)}
.bar-blue{background:rgba(59,139,240,.35)}
.chart-labels{display:flex;justify-content:space-between;font-size:9px;color:var(--muted)}

/* ===== TABLES ===== */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;color:var(--muted);font-weight:500;font-size:9px;text-transform:uppercase;letter-spacing:.1em;padding:6px 10px;border-bottom:1px solid var(--border)}
td{padding:9px 10px;border-bottom:1px solid rgba(232,160,32,.06);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(232,160,32,.03)}

/* ===== BADGES ===== */
.badge{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:10px;letter-spacing:.06em;white-space:nowrap}
.bg-green{background:rgba(34,197,94,.14);color:var(--green)}
.bg-gold{background:rgba(232,160,32,.14);color:var(--gold)}
.bg-red{background:rgba(230,0,35,.14);color:var(--red)}
.bg-blue{background:rgba(59,139,240,.14);color:var(--blue)}
.bg-gray{background:rgba(255,255,255,.08);color:var(--muted2)}

/* ===== PROGRESS ===== */
.prog-wrap{margin-bottom:10px}
.prog-row{display:flex;justify-content:space-between;font-size:11px;margin-bottom:4px}
.prog-bar{background:rgba(255,255,255,.07);border-radius:4px;height:5px}
.prog-fill{height:100%;border-radius:4px;transition:width .4s}

/* ===== FORMS ===== */
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.form-row-3{grid-template-columns:1fr 1fr 1fr}
.form-row-1{grid-template-columns:1fr}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em}
.form-input{background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--text);padding:8px 10px;border-radius:7px;font-size:12px;font-family:inherit;width:100%;transition:border .15s}
.form-input:focus{outline:none;border-color:var(--gold)}
.form-input::placeholder{color:var(--muted)}
select.form-input option{background:var(--dark);color:var(--text)}
textarea.form-input{resize:vertical;min-height:72px}
.btn-row{display:flex;gap:10px;margin-top:4px}
.btn-primary{background:var(--gold);color:var(--dark);border:none;padding:9px 20px;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;transition:opacity .15s}
.btn-primary:hover{opacity:.85}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--muted);padding:9px 16px;border-radius:7px;font-size:12px;cursor:pointer;transition:all .15s}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold)}
.btn-danger{background:rgba(230,0,35,.12);border:1px solid var(--danger-border);color:var(--red);padding:4px 10px;border-radius:5px;font-size:10px;cursor:pointer;transition:all .15s}
.btn-danger:hover{background:rgba(230,0,35,.22)}
.btn-sm{padding:4px 10px;font-size:10px;border-radius:5px}
.btn-action{background:transparent;border:1px solid var(--border);color:var(--muted);padding:4px 10px;border-radius:5px;font-size:10px;cursor:pointer;transition:all .15s;margin-right:4px}
.btn-action:hover{border-color:var(--gold);color:var(--gold)}

/* ===== COPY LINKS ===== */
.cat-filter{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px}
.cat-chip{background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--muted);font-size:11px;padding:5px 13px;border-radius:20px;cursor:pointer;transition:all .15s;user-select:none}
.cat-chip:hover{border-color:var(--gold);color:var(--gold)}
.cat-chip.active{background:var(--gold);color:var(--dark);border-color:var(--gold);font-weight:700}

.article-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(232,160,32,.07);gap:8px}
.article-row:last-child{border-bottom:none}
.article-title{font-size:12px;color:var(--text);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0}
.cat-tag{font-size:9px;padding:2px 8px;border-radius:10px;background:rgba(232,160,32,.1);color:var(--gold);border:1px solid var(--border);white-space:nowrap;flex-shrink:0}
.copy-btn{background:rgba(232,160,32,.08);border:1px solid var(--border);color:var(--gold);font-size:10px;padding:4px 12px;border-radius:6px;cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0}
.copy-btn:hover{background:var(--gold);color:var(--dark)}
.copy-btn.copied{background:var(--green);color:#fff;border-color:var(--green)}

/* ===== EARNINGS CALC ===== */
.rpm-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(232,160,32,.07);font-size:12px}
.rpm-row:last-child{border-bottom:none}
.rpm-label{color:var(--muted)}
.rpm-val{font-weight:600;color:var(--text)}

/* ===== LOGIN SCREEN ===== */
#login-screen{position:fixed;inset:0;background:var(--dark);display:flex;align-items:center;justify-content:center;z-index:999}
.login-box{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:36px 32px;width:100%;max-width:360px}
.login-logo{text-align:center;margin-bottom:28px}
.login-title{font-size:20px;font-weight:700;color:var(--gold);margin-bottom:4px}
.login-sub{font-size:11px;color:var(--muted);letter-spacing:.06em}
.login-form{display:flex;flex-direction:column;gap:14px}
.login-err{background:var(--danger-bg);border:1px solid var(--danger-border);color:var(--red);font-size:11px;padding:8px 12px;border-radius:7px;display:none;text-align:center}
.login-err.show{display:block}
.forgot-link{font-size:10px;color:var(--muted);text-align:right;cursor:pointer;text-decoration:underline;margin-top:-6px}
.forgot-link:hover{color:var(--gold)}

/* ===== USER SWITCHER TAB ===== */
.view-tabs{display:flex;gap:0;margin-bottom:0;border-bottom:1px solid var(--border)}
.view-tab{padding:8px 18px;font-size:11px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;letter-spacing:.04em}
.view-tab:hover{color:var(--gold-l)}
.view-tab.active{color:var(--gold);border-bottom-color:var(--gold);font-weight:600}

/* ===== ANALYTICS CARDS ===== */
.analytics-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.a-card{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:12px 14px;position:relative}
.a-card-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:5px}
.a-card-val{font-size:18px;font-weight:700}
.a-card-icon{position:absolute;top:12px;right:12px;font-size:18px;opacity:.25}

/* ===== INFO BOX ===== */
.info-box{background:rgba(59,139,240,.08);border:1px solid rgba(59,139,240,.2);border-radius:8px;padding:12px 14px;font-size:11px;color:var(--blue);line-height:1.7;margin-bottom:14px}
.warning-box{background:rgba(232,160,32,.08);border:1px solid rgba(232,160,32,.2);border-radius:8px;padding:12px 14px;font-size:11px;color:var(--gold);line-height:1.7;margin-bottom:14px}

/* ===== LOADER ===== */
.loader{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--muted);padding:20px 0}
.spinner{width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* ===== RESPONSIVE ===== */
@media(max-width:900px){
  #sidebar{width:50px}
  .nav-item span:not(.nav-icon){display:none}
  .nav-section,.user-name,.user-role,.logo-name,.logo-domain,.pin-badge{display:none}
  .user-avatar{margin:0 auto}
  .stat-grid{grid-template-columns:repeat(2,1fr)}
  .grid-2,.grid-3{grid-template-columns:1fr}
}
</style>
</head>
