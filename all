  return `<div class="nav-item" data-panel="${panel}"><span class="nav-icon">${icon}</span>${label}${extra}</div>`;
}

function showPanel(id){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const p = document.getElementById('panel-'+id);
  if(p) p.classList.add('active');
  const n = document.querySelector(`[data-panel="${id}"]`);
  if(n) n.classList.add('active');

  const titles={
    'admin-overview':'Admin Overview',
    'admin-users':'User Management',
    'admin-payments':'Payments & Earnings',
    'admin-analytics':'Analytics — captionmood.com',
    'admin-articles':'Article Sync — WordPress REST API',
    'user-articles':'Article Links — captionmood.com',
    'user-earnings':'My Earnings',
    'user-reports':'My Reports',
  };
  document.getElementById('page-title').textContent = titles[id]||id;

  // Render panel data
  if(id==='admin-overview') renderAdminOverview();
  if(id==='admin-users') renderUsers();
  if(id==='admin-payments') renderPayments();
  if(id==='admin-analytics') renderAnalytics();
  if(id==='admin-articles') renderWPArticles();
  if(id==='user-articles') renderUserArticles();
  if(id==='user-earnings') renderUserEarnings();
  if(id==='user-reports') renderUserReports();
}

