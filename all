<!-- ===== LOGIN SCREEN ===== -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">
      <div style="display:inline-block;background:var(--pin);color:#fff;font-size:9px;font-weight:700;padding:2px 8px;border-radius:3px;letter-spacing:.1em;margin-bottom:8px;">PINTEREST</div>
      <div class="login-title">Social Gold</div>
      <div class="login-sub">socialgold.com · captionmood.com</div>
    </div>
    <div class="login-form">
      <div class="login-err" id="login-err">Invalid email or password.</div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-input" id="l-email" placeholder="your@email.com" onkeydown="if(event.key==='Enter')doLogin()" />
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" class="form-input" id="l-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()" />
      </div>
      <div class="forgot-link" onclick="alert('Contact admin to reset password.')">Forgot password?</div>
      <button class="btn-primary" style="width:100%;padding:11px;" onclick="doLogin()">Sign In</button>
      <div style="font-size:10px;color:var(--muted);text-align:center;margin-top:-4px;">
        Demo: admin@socialgold.com / admin123<br>user@socialgold.com / user123
      </div>
    </div>
  </div>
</div>

<!-- ===== MAIN APP ===== -->
<div id="app">

  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="logo-area">
      <div class="pin-badge">PINTEREST</div>
      <div class="logo-name">Social Gold</div>
      <div class="logo-domain">socialgold.com</div>
    </div>
    <nav class="nav" id="nav">
