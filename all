    <div id="topbar">
      <div class="topbar-left">
        <div class="page-title" id="page-title">Dashboard</div>
        <div class="sync-dot"></div>
        <div class="sync-label" id="sync-label">Live</div>
      </div>
      <div class="topbar-right">
