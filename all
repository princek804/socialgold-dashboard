// ============================================================
// ADMIN: USERS
// ============================================================
function renderUsers(){
  renderUsersTable(allUsers);
  document.getElementById('u-total').textContent = allUsers.length;
}

function renderUsersTable(users){
  const tbody = document.getElementById('users-table-body');
  tbody.innerHTML = users.map((u,i)=>`<tr>
    <td><strong>${u.name}</strong></td>
    <td style="color:var(--muted);">${u.email}</td>
    <td><span class="badge ${roleBadge(u.role)}">${u.role}</span></td>
    <td><span style="font-size:10px;">${u.cat}</span></td>
    <td>${fmtN(u.clicks)}</td>
    <td style="color:var(--green);">${fmt$(u.earned)}</td>
    <td>${statusBadge(u.status)}</td>
    <td>
      <button class="btn-action" onclick="editUser(${u.id})">Edit</button>
      ${u.status==='active'
        ? `<button class="btn-danger btn-sm" onclick="toggleUser(${u.id})">Suspend</button>`
        : `<button class="btn-action" style="border-color:rgba(34,197,94,.3);color:var(--green);" onclick="toggleUser(${u.id})">Restore</button>`}
    </td>
  </tr>`).join('');
}

function roleBadge(r){
  return {Admin:'bg-red',Editor:'bg-gold',Moderator:'bg-blue',User:'bg-blue'}[r]||'bg-gray';
}

function catColor(c){
  const m={Captions:'bg-blue',Quotes:'bg-blue',Love:'bg-red',Humor:'bg-gold',Motivation:'bg-green',Birthday:'bg-blue'};
  return m[c]||'bg-gray';
}

function addUser(){
  const name=document.getElementById('nu-name').value.trim();
  const email=document.getElementById('nu-email').value.trim();
  const pass=document.getElementById('nu-pass').value.trim();
  const role=document.getElementById('nu-role').value;
  const cat=document.getElementById('nu-cat').value;
  const pay=document.getElementById('nu-pay').value;
  if(!name||!email||!pass){toast('Please fill all required fields.','error');return;}
  if(allUsers.find(u=>u.email.toLowerCase()===email.toLowerCase())){toast('Email already exists.','error');return;}
  const newUser={id:Date.now(),name,email,pass,role,cat,pay,clicks:0,earned:0,status:'active'};
  allUsers.push(newUser);
  DB.users.push(newUser);
  renderUsersTable(allUsers);
  document.getElementById('u-total').textContent=allUsers.length;
  clearAddUser();
  toast(`User "${name}" added successfully!`);
}

function clearAddUser(){
  ['nu-name','nu-email','nu-pass'].forEach(id=>document.getElementById(id).value='');
}

function toggleUser(id){
  const u=allUsers.find(x=>x.id===id);
  if(!u)return;
  u.status=u.status==='active'?'suspended':'active';
  renderUsersTable(allUsers);
  toast(`User "${u.name}" ${u.status==='active'?'restored':'suspended'}.`);
}

function editUser(id){
  const u=allUsers.find(x=>x.id===id);
  if(!u)return;
  toast(`Edit: ${u.name} — Full edit form coming in next version.`);
}

function searchUsers(q){
  const filtered=q?allUsers.filter(u=>u.name.toLowerCase().includes(q.toLowerCase())||u.email.toLowerCase().includes(q.toLowerCase())):allUsers;
  renderUsersTable(filtered);
}

