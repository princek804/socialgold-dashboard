// ============================================================
// ADMIN: WP ARTICLE SYNC
// ============================================================
let wpArticles = [...DB.articles];

function renderWPArticles(){
  document.getElementById('wp-article-count').textContent = `(${wpArticles.length} articles)`;
  renderWPArticleList(wpArticles);
}

function renderWPArticleList(articles){
  const el=document.getElementById('wp-articles-list');
  if(!articles.length){el.innerHTML='<div style="color:var(--muted);font-size:12px;padding:12px 0;">No articles found.</div>';return;}
  el.innerHTML=`<table>
    <thead><tr><th>Title</th><th>Category</th><th>URL</th><th>Date</th><th>Clicks</th></tr></thead>
    <tbody>${articles.map(a=>`<tr>
      <td style="max-width:240px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${a.title}</td>
      <td><span class="badge ${catColor(a.cat)}">${a.cat}</span></td>
      <td><a href="${a.url}" style="color:var(--blue);font-size:10px;" target="_blank">View</a></td>
      <td style="color:var(--muted);font-size:11px;">${a.date}</td>
      <td>${fmtN(a.clicks)}</td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function fetchWPArticles(){
  const url=document.getElementById('wp-url').value.trim()||'https://captionmood.com';
  const statusEl=document.getElementById('wp-sync-status');
  document.getElementById('wp-articles-list').innerHTML='<div class="loader"><div class="spinner"></div>Fetching from '+url+'/wp-json/wp/v2/posts...</div>';
  statusEl.innerHTML=`<span style="color:var(--gold);">Connecting to WordPress REST API: ${url}/wp-json/wp/v2/posts?per_page=100</span>`;

  // Simulate real WP API call (replace with real fetch in production)
  setTimeout(()=>{
    // In production: fetch(`${url}/wp-json/wp/v2/posts?per_page=100`)
    //   .then(r=>r.json()).then(posts=>{ ... map posts to articles ... })
    const now = new Date().toISOString().split('T')[0];
    const newArticle = {
      id: Date.now(),
      title: "New Auto-Synced: Latest Captions 2025 — "+new Date().toLocaleTimeString(),
      cat: "Captions",
      url: url+"/new-captions-"+Date.now(),
      clicks: 0,
      date: now
    };
    wpArticles.unshift(newArticle);
    DB.articles.unshift(newArticle);
    document.getElementById('wp-article-count').textContent=`(${wpArticles.length} articles)`;
    renderWPArticleList(wpArticles);
    statusEl.innerHTML=`<span style="color:var(--green);">✓ Sync complete — ${wpArticles.length} articles loaded. Last sync: ${new Date().toLocaleTimeString()}</span>`;
    toast('Articles synced from captionmood.com!');
  }, 1800);
}

function searchWPArticles(q){
  const filtered=q?wpArticles.filter(a=>a.title.toLowerCase().includes(q.toLowerCase())||a.cat.toLowerCase().includes(q.toLowerCase())):wpArticles;
  renderWPArticleList(filtered);
}

// ============================================================
// USER: ARTICLE LINKS
// ============================================================
function renderUserArticles(){
  // Build category chips
  const cats=['all',...DB.categories];
  document.getElementById('user-cat-filter').innerHTML=cats.map(c=>`
    <div class="cat-chip ${c===userArticleFilter?'active':''}" data-cat="${c}" onclick="setUserCat('${c}')">${c==='all'?'All Categories':c}</div>
  `).join('');
  renderUserArticlesList();
}

function setUserCat(cat){
  userArticleFilter=cat;
  renderUserArticles();
}

function filterUserArticles(q){
  userArticleSearch=q;
  renderUserArticlesList();
}

function renderUserArticlesList(){
  let arts = DB.articles;
  if(userArticleFilter!=='all') arts=arts.filter(a=>a.cat===userArticleFilter);
  if(userArticleSearch) arts=arts.filter(a=>a.title.toLowerCase().includes(userArticleSearch.toLowerCase()));

  document.getElementById('articles-count-label').textContent=`${arts.length} article${arts.length!==1?'s':''}${userArticleFilter!=='all'?' in '+userArticleFilter:''}`;

  const el=document.getElementById('user-articles-list');
  if(!arts.length){el.innerHTML='<div style="color:var(--muted);font-size:12px;padding:10px 0;">No articles found for this filter.</div>';return;}

  el.innerHTML=arts.map((a,i)=>`<div class="article-row">
    <span class="article-title" title="${a.url}">${a.title}</span>
    <span class="cat-tag">${a.cat}</span>
    <button class="copy-btn" id="ubtn-${i}" onclick="copyUserLink('${a.url}',${i},'${a.title}')">Copy Link</button>
  </div>`).join('');
}

function copyUserLink(url,i,title){
  try{ navigator.clipboard.writeText(url); }catch(e){}
  const btn=document.getElementById('ubtn-'+i);
  if(btn){btn.textContent='Copied!';btn.classList.add('copied');setTimeout(()=>{btn.textContent='Copy Link';btn.classList.remove('copied');},1800);}
  toast('Link copied: '+title.slice(0,40)+'...');
}

